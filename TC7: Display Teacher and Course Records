import java.util.ArrayList;

class Teacher {
    private String name;
    private String id;
    private String specialization;

    public Teacher(String name, String id, String specialization) {
        this.name = name;
        this.id = id;
        this.specialization = specialization;
    }

    public void displayInfo() {
        System.out.println("Teacher Name: " + name);
        System.out.println("Teacher ID: " + id);
        System.out.println("Specialization: " + specialization);
        System.out.println("----------------------");
    }
}

class Course {
    private String code;
    private String name;

    public Course(String code, String name) {
        this.code = code;
        this.name = name;
    }

    public void displayCourse() {
        System.out.println("Course Code: " + code);
        System.out.println("Course Name: " + name);
        System.out.println("----------------------");
    }
}

public class Main {
    public static void main(String[] args) {

        // Teacher list
        ArrayList<Teacher> teachers = new ArrayList<>();
        teachers.add(new Teacher("Sir Nazmirul", "T001", "Java"));
        teachers.add(new Teacher("Madam Aisha", "T002", "Database"));

        // Course list
        ArrayList<Course> courses = new ArrayList<>();
        courses.add(new Course("BIT1123", "OOP"));
        courses.add(new Course("BIT1133", "Database System"));

        // TC7: Display Teachers
        System.out.println("=== Teacher Records ===");
        for (Teacher t : teachers) {
            t.displayInfo();
        }

        // Display Courses
        System.out.println("=== Course Records ===");
        for (Course c : courses) {
            c.displayCourse();
        }
    }
}
